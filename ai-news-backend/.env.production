# Production Environment Configuration
# Copy to .env and fill in secrets
# DO NOT commit .env to version control

# ---- Application ----
APP_ENV=production
APP_NAME=EntropyGate AI
API_VERSION=v1
SECRET_KEY=change-me-to-random-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- Database ----
DATABASE_URL=sqlite:///./ainews.db
# For PostgreSQL production:
# DATABASE_URL=postgresql://user:pass@db:5432/ainews

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- CORS ----
CORS_ORIGINS=https://entropygate.ai,https://api.entropygate.ai

# ---- Crawler ----
CRAWLER_ENABLED=true
CRAWLER_INTERVAL_MINUTES=60
CRAWLER_MAX_CONCURRENT=3

# ---- LLM ----
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4

# ---- Monitoring ----
HEALTH_CHECK_PORT=8080
LOG_LEVEL=INFO
METRICS_ENABLED=true

# ---- Backup ----
BACKUP_DIR=/app/backups
BACKUP_KEEP_DAYS=30
BACKUP_SCHEDULE=daily

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
